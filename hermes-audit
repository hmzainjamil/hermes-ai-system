run_test H71 "hermes-watch.plist exists" \
  "[ -f ~/Library/LaunchAgents/ai.hmz.hermes-watch.plist ]"

run_test H72 "hermes-watch.plist references hermes-autodetect" \
  "grep -q 'hermes-autodetect' ~/Library/LaunchAgents/ai.hmz.hermes-watch.plist 2>/dev/null"

run_test H73 "launchctl list shows hermes loaded" \
  "launchctl list 2>/dev/null | grep -q hermes"

run_test H74 "hermes-autodetect binary exists at ~/.claude/bin/" \
  "[ -f ~/.claude/bin/hermes-autodetect ]"

run_test H75 "hermes-autodetect is executable" \
  "[ -x ~/.claude/bin/hermes-autodetect ]"

run_test H76 "system-status binary exists at ~/.claude/bin/" \
  "[ -f ~/.claude/bin/system-status ]"

run_test H77 "system-status is executable" \
  "[ -x ~/.claude/bin/system-status ]"

run_test H78 "~/.claude/agents/hermes-nous-agent.md exists" \
  "[ -f ~/.claude/agents/hermes-nous-agent.md ]"

run_test H79 "hermes-orchestrator exists at ~/.claude/bin/" \
  "[ -f ~/.claude/bin/hermes-orchestrator ]"

run_test H80 "hermes-orchestrator is executable" \
  "[ -x ~/.claude/bin/hermes-orchestrator ]"

