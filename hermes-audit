# ─────────────────────────────────────────────
TOTAL=$((PASS + FAIL + SKIP))
echo "════════════════════════════════════════"
echo "  RESULTS: $TOTAL tests run"
echo "  ✓ PASS : $PASS"
echo "  ✗ FAIL : $FAIL"
echo "  ~ SKIP : $SKIP"
echo "════════════════════════════════════════"

if [ ${#FAILURES_LIST[@]} -gt 0 ]; then
  echo ""
  echo "FAILURES:"
  for entry in "${FAILURES_LIST[@]}"; do
    echo "  ✗ $entry"
  done
fi

echo ""
if [ $FAIL -eq 0 ]; then
  echo "  ALL TESTS PASSED (or skipped)"
  exit 0
else
  echo "  $FAIL TEST(S) FAILED"
  exit 1
fi
