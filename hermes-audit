  "which hermes >/dev/null 2>&1 || [ -x ~/.local/bin/hermes ]"

run_test I89 "adapter references hermes chat" \
  "grep -rq 'hermes.*chat\|hermes chat' ~/installed-repos/hermes-paperclip-adapter/ 2>/dev/null"

if $PAPERCLIP_UP; then
  run_test I90 "paperclip server is running (port 3100 open)" \
    "curl -s --max-time 3 http://127.0.0.1:3100 >/dev/null"
else
  skip_test I90 "Paperclip server port 3100 (unreachable)"
