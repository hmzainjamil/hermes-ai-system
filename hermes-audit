#!/usr/bin/env bash
# hermes-audit — 100-test suite for full Hermes stack
PASS=0; FAIL=0; SKIP=0
FAILURES_LIST=()  # bash 3/4/5 compat array

source ~/.zshrc 2>/dev/null
source ~/.hermes/.env 2>/dev/null

run_test() {
  local id="$1" desc="$2" cmd="$3"
  if eval "$cmd" >/dev/null 2>&1; then
    echo "  ✓ [$id] $desc"
    ((PASS++))
  else
    echo "  ✗ [$id] $desc"
    FAILURES_LIST+=("[$id] $desc")
    ((FAIL++))
  fi
}

run_live() {
  local id="$1" desc="$2" cmd="$3"
  local out tmpf
  tmpf=$(mktemp /tmp/hermes-audit-XXXX)
  ( eval "$cmd" > "$tmpf" 2>&1 ) &
  local bgpid=$!
  local waited=0
  while kill -0 "$bgpid" 2>/dev/null && [ $waited -lt 90 ]; do
    sleep 2; ((waited+=2))
  done
  kill "$bgpid" 2>/dev/null; wait "$bgpid" 2>/dev/null
  out=$(cat "$tmpf" 2>/dev/null); rm -f "$tmpf"
  sleep 8  # stagger — local model needs warm-up time — prevent free-tier rate limits on consecutive live calls
  if [ $waited -ge 90 ] && [ -z "$out" ]; then
    echo "  ~ [$id] $desc (TIMEOUT)"
    ((SKIP++))
  elif [ -n "$out" ]; then
    echo "  ✓ [$id] $desc"
    ((PASS++))
  else
    echo "  ✗ [$id] $desc"
    FAILURES_LIST+=("[$id] $desc")
    ((FAIL++))
  fi
}

skip_test() {
  local id="$1" desc="$2"
  echo "  ~ [$id] $desc (SKIP)"
  ((SKIP++))
}

PAPERCLIP_UP=false
if curl -s --max-time 3 http://127.0.0.1:3100/api/health >/dev/null 2>&1; then
  PAPERCLIP_UP=true
fi

echo "=== HERMES STACK AUDIT — 100 TESTS ==="
echo ""

# ─────────────────────────────────────────────
echo "── GROUP A: Binary & Install ──"
run_test A01 "hermes binary exists at ~/.local/bin/hermes" \
  "[ -f ~/.local/bin/hermes ]"

run_test A02 "hermes symlink resolves (follow -L)" \
  "[ -L ~/.local/bin/hermes ] || [ -f ~/.local/bin/hermes ]"

run_test A03 "hermes --version returns Hermes Agent v0.13.0" \
  "hermes --version 2>/dev/null | grep -q 'Hermes Agent v0.13.0' || ~/.local/bin/hermes --version 2>/dev/null | grep -q '0.13.0'"

run_test A04 "python 3.11 available in hermes uv env" \
  "[ -f ~/.local/share/uv/tools/hermes-agent/bin/python3.11 ] || [ -f ~/.local/share/uv/python/cpython-3.11.15-macos-aarch64-none/bin/python3.11 ]"

run_test A05 "uv tool list shows hermes-agent" \
  "uv tool list 2>/dev/null | grep -qi 'hermes'"

run_test A06 "hermes-agent repo has >5 files" \
  "[ \$(ls ~/installed-repos/hermes-agent 2>/dev/null | wc -l) -gt 5 ]"

run_test A07 "hermes-paperclip-adapter dist/index.js exists" \
  "[ -f ~/installed-repos/hermes-paperclip-adapter/dist/index.js ]"

run_test A08 "hermes-paperclip-adapter package.json shows v0.3.0" \
  "grep -q '0.3.0' ~/installed-repos/hermes-paperclip-adapter/package.json 2>/dev/null"

run_test A09 "Hermes-Function-Calling repo has functioncall.py" \
  "[ -f ~/installed-repos/Hermes-Function-Calling/functioncall.py ]"

run_test A10 "hermes-agent-self-evolution has evolution module" \
