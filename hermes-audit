if $PAPERCLIP_UP; then
  run_test I81 "Paperclip health endpoint returns 200" \
    "curl -s --max-time 5 -o /dev/null -w '%{http_code}' http://127.0.0.1:3100/api/health | grep -q '200'"
else
  skip_test I81 "Paperclip health endpoint (port 3100 unreachable)"
fi

run_test I82 "hermes-paperclip-adapter dist/index.js exists" \
  "[ -f ~/installed-repos/hermes-paperclip-adapter/dist/index.js ]"

run_test I83 "adapter package.json has version 0.3.0" \
  "grep -q '0.3.0' ~/installed-repos/hermes-paperclip-adapter/package.json 2>/dev/null"

run_test I84 "paperclip registry.ts has hermes_local" \
  "grep -q 'hermes_local\|hermes' ~/installed-repos/paperclip/server/src/adapters/registry.ts 2>/dev/null"

run_test I85 "adapter node_modules exists" \
  "[ -d ~/installed-repos/hermes-paperclip-adapter/node_modules ]"

if $PAPERCLIP_UP; then
  run_test I86 "Paperclip version >= 0.3.0" \
    "curl -s --max-time 5 http://127.0.0.1:3100/api/health 2>/dev/null | grep -q '0\.[3-9]\|[1-9]\.[0-9]'"
else
  skip_test I86 "Paperclip version check (port 3100 unreachable)"
fi

if $PAPERCLIP_UP; then
  run_test I87 "Paperclip /api/health returns ok status" \
    "curl -s --max-time 5 http://127.0.0.1:3100/api/health | grep -q '\"status\":\"ok\"'"
else
